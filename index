<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Equipment Vendor Comparison — Truvet SG</title>
<style>
  :root {
    --bg: #0d1117;
    --surface: #161b22;
    --surface2: #1c2330;
    --border: #30363d;
    --accent: #00b4d8;
    --accent2: #e63946;
    --accent3: #2ec4b6;
    --text-primary: #e6edf3;
    --text-secondary: #8b949e;
    --text-dim: #484f58;
    --green: #3fb950;
    --yellow: #d29922;
    --red: #f85149;
    --tag-bg: #21262d;
    --canaan-color: #00b4d8;
    --urban-color: #2ec4b6;
    --winner: #3fb950;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--text-primary);
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    font-size: 14px;
    line-height: 1.6;
  }

  /* HEADER */
  .header {
    border-bottom: 1px solid var(--border);
    padding: 28px 40px 20px;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .header-left h1 {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.5px;
    color: var(--text-primary);
  }
  .header-left .subtitle {
    color: var(--text-secondary);
    font-size: 13px;
    margin-top: 4px;
  }
  .header-cards {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .vendor-pill {
    padding: 8px 18px;
    border-radius: 6px;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.3px;
  }
  .vendor-pill.canaan { background: rgba(0,180,216,0.15); border: 1px solid var(--canaan-color); color: var(--canaan-color); }
  .vendor-pill.urban  { background: rgba(46,196,182,0.15); border: 1px solid var(--urban-color); color: var(--urban-color); }

  /* TABS */
  .tab-bar {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--border);
    padding: 0 40px;
    overflow-x: auto;
  }
  .tab-btn {
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    color: var(--text-secondary);
    cursor: pointer;
    font-size: 13px;
    font-weight: 500;
    padding: 12px 18px;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s;
  }
  .tab-btn:hover { color: var(--text-primary); }
  .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }

  /* MAIN CONTENT */
  .main { padding: 32px 40px; max-width: 1400px; }
  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* SUMMARY CARDS */
  .summary-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 32px;
  }
  .vendor-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 24px;
  }
  .vendor-card.canaan { border-top: 3px solid var(--canaan-color); }
  .vendor-card.urban  { border-top: 3px solid var(--urban-color); }
  .vendor-card h2 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 4px;
  }
  .vendor-card .location {
    font-size: 11px;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    margin-bottom: 16px;
  }
  .price-big {
    font-size: 30px;
    font-weight: 800;
    letter-spacing: -1px;
    margin-bottom: 4px;
  }
  .price-big.canaan { color: var(--canaan-color); }
  .price-big.urban  { color: var(--urban-color); }
  .price-label { font-size: 11px; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 16px; }
  .kv-list { display: grid; grid-template-columns: auto 1fr; gap: 6px 16px; align-items: center; }
  .kv-list .kv-key { font-size: 12px; color: var(--text-secondary); white-space: nowrap; }
  .kv-list .kv-val { font-size: 12px; color: var(--text-primary); font-weight: 500; }
  .divider { border: none; border-top: 1px solid var(--border); margin: 14px 0; }

  /* SAVINGS CALLOUT */
  .savings-bar {
    background: rgba(46,196,182,0.08);
    border: 1px solid rgba(46,196,182,0.3);
    border-radius: 8px;
    padding: 14px 20px;
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }
  .savings-bar .label { font-size: 12px; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.6px; }
  .savings-bar .number { font-size: 24px; font-weight: 800; color: var(--urban-color); letter-spacing: -0.5px; }
  .savings-bar .note { font-size: 12px; color: var(--text-secondary); }

  /* COMPARISON TABLE */
  .section-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-secondary);
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .section-label:not(:first-child) { margin-top: 32px; }

  .comp-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
    margin-bottom: 8px;
  }
  .comp-table thead th {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 10px 14px;
    font-weight: 700;
    text-align: left;
    font-size: 12px;
    letter-spacing: 0.3px;
    color: var(--text-secondary);
    white-space: nowrap;
  }
  .comp-table thead th.canaan-col { color: var(--canaan-color); }
  .comp-table thead th.urban-col  { color: var(--urban-color); }
  .comp-table thead th.diff-col   { color: var(--yellow); text-align: center; }
  .comp-table tbody tr:hover { background: rgba(255,255,255,0.02); }
  .comp-table tbody td {
    border: 1px solid var(--border);
    padding: 10px 14px;
    vertical-align: top;
  }
  .comp-table tbody td.cat-col {
    font-weight: 600;
    color: var(--text-primary);
    min-width: 160px;
  }
  .comp-table tbody td.model-col {
    font-size: 11px;
    color: var(--text-secondary);
    font-style: italic;
  }
  .price-cell {
    font-weight: 700;
    white-space: nowrap;
    text-align: right;
  }
  .price-cell.canaan { color: var(--canaan-color); }
  .price-cell.urban  { color: var(--urban-color); }
  .spec-text { font-size: 12px; color: var(--text-secondary); }
  .spec-highlight { font-size: 12px; color: var(--green); font-weight: 600; }
  .spec-warning { font-size: 12px; color: var(--yellow); }
  .badge {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-left: 6px;
    vertical-align: middle;
    white-space: nowrap;
  }
  .badge.green { background: rgba(63,185,80,0.15); color: var(--green); border: 1px solid rgba(63,185,80,0.3); }
  .badge.yellow { background: rgba(210,153,34,0.15); color: var(--yellow); border: 1px solid rgba(210,153,34,0.3); }
  .badge.red { background: rgba(248,81,73,0.15); color: var(--red); border: 1px solid rgba(248,81,73,0.3); }
  .badge.blue { background: rgba(0,180,216,0.15); color: var(--canaan-color); border: 1px solid rgba(0,180,216,0.3); }
  .badge.teal { background: rgba(46,196,182,0.15); color: var(--urban-color); border: 1px solid rgba(46,196,182,0.3); }

  .diff-cell {
    text-align: center;
    font-weight: 700;
    white-space: nowrap;
    font-size: 12px;
  }
  .diff-cell.cheaper { color: var(--green); }
  .diff-cell.expensive { color: var(--red); }
  .diff-cell.similar { color: var(--text-secondary); }

  /* TOTALS ROW */
  .total-row td {
    background: var(--surface2) !important;
    font-weight: 800 !important;
    font-size: 14px !important;
    border-top: 2px solid var(--border) !important;
  }

  /* TERMS TABLE */
  .terms-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
  }
  .terms-table thead th {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 10px 16px;
    font-weight: 700;
    font-size: 12px;
    text-align: left;
    color: var(--text-secondary);
  }
  .terms-table thead th.canaan-col { color: var(--canaan-color); }
  .terms-table thead th.urban-col  { color: var(--urban-color); }
  .terms-table tbody td {
    border: 1px solid var(--border);
    padding: 12px 16px;
    vertical-align: top;
  }
  .terms-table tbody td:first-child {
    font-weight: 600;
    color: var(--text-secondary);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    white-space: nowrap;
    background: var(--surface);
    min-width: 140px;
  }
  .terms-table tbody tr:hover td { background: rgba(255,255,255,0.02); }
  .terms-table tbody tr:hover td:first-child { background: var(--surface); }

  /* VERDICT */
  .verdict-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 28px;
  }
  .verdict-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px;
  }
  .verdict-box h3 {
    font-size: 14px;
    font-weight: 700;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .verdict-box ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .verdict-box li {
    font-size: 13px;
    color: var(--text-secondary);
    padding-left: 20px;
    position: relative;
  }
  .verdict-box li::before {
    position: absolute;
    left: 0;
    top: 0;
    font-size: 13px;
  }
  .verdict-box.pros li::before { content: "↑"; color: var(--green); }
  .verdict-box.cons li::before { content: "↓"; color: var(--red); }

  .recommendation-box {
    background: rgba(0,180,216,0.05);
    border: 1px solid rgba(0,180,216,0.2);
    border-left: 4px solid var(--canaan-color);
    border-radius: 8px;
    padding: 24px;
    margin-bottom: 24px;
  }
  .recommendation-box h3 {
    font-size: 16px;
    font-weight: 800;
    color: var(--canaan-color);
    margin-bottom: 12px;
    letter-spacing: -0.3px;
  }
  .recommendation-box p {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 10px;
  }
  .recommendation-box p strong { color: var(--text-primary); }
  .recommendation-box p:last-child { margin-bottom: 0; }

  .risk-box {
    background: rgba(210,153,34,0.06);
    border: 1px solid rgba(210,153,34,0.25);
    border-left: 4px solid var(--yellow);
    border-radius: 8px;
    padding: 20px 24px;
    margin-top: 20px;
  }
  .risk-box h4 { font-size: 13px; font-weight: 700; color: var(--yellow); margin-bottom: 10px; }
  .risk-box ul { list-style: none; display: flex; flex-direction: column; gap: 6px; }
  .risk-box li { font-size: 13px; color: var(--text-secondary); padding-left: 18px; position: relative; }
  .risk-box li::before { content: "⚠"; position: absolute; left: 0; font-size: 11px; }

  .ratio-bar {
    margin: 24px 0;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px 20px;
  }
  .ratio-bar h4 { font-size: 12px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 12px; }
  .bar-row { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
  .bar-label { font-size: 12px; color: var(--text-secondary); width: 180px; flex-shrink: 0; }
  .bar-track { flex: 1; background: var(--tag-bg); border-radius: 4px; height: 8px; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 4px; transition: width 0.6s ease; }
  .bar-fill.canaan { background: var(--canaan-color); }
  .bar-fill.urban  { background: var(--urban-color); }
  .bar-val { font-size: 12px; font-weight: 700; width: 80px; text-align: right; flex-shrink: 0; }

  @media (max-width: 900px) {
    .header { padding: 20px; }
    .main { padding: 20px; }
    .tab-bar { padding: 0 20px; }
    .summary-grid, .verdict-grid { grid-template-columns: 1fr; }
    .comp-table { font-size: 11px; }
  }

  /* Filter row */
  .filter-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .filter-row label { font-size: 12px; color: var(--text-secondary); }
  .filter-btn {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 5px;
    color: var(--text-secondary);
    cursor: pointer;
    font-size: 12px;
    padding: 5px 12px;
    transition: all 0.15s;
  }
  .filter-btn:hover, .filter-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
</style>
</head>
<body>

<div class="header">
  <div class="header-left">
    <h1>Pharmaceutical Equipment — Vendor Comparison</h1>
    <div class="subtitle">Truvet SG · Full GMP Manufacturing Line · Analysis as of June 2026</div>
  </div>
  <div class="header-cards">
    <div class="vendor-pill canaan">Canaan Technology · Wenzhou</div>
    <div class="vendor-pill urban">Urban Machinery · Ruian</div>
  </div>
</div>

<div class="tab-bar">
  <button class="tab-btn active" onclick="showTab('overview')">Overview</button>
  <button class="tab-btn" onclick="showTab('granulation')">Granulation Line</button>
  <button class="tab-btn" onclick="showTab('packaging')">Packaging Line</button>
  <button class="tab-btn" onclick="showTab('terms')">Commercial Terms</button>
  <button class="tab-btn" onclick="showTab('verdict')">Recommendation</button>
</div>

<div class="main">

  <!-- ===== OVERVIEW ===== -->
  <div class="tab-content active" id="tab-overview">
    <div class="summary-grid">
      <div class="vendor-card canaan">
        <h2>Canaan Technology Limited</h2>
        <div class="location">Wenzhou, Zhejiang · QE26061219138-VER1 · 13 Jun 2026</div>
        <div class="price-big canaan">USD $761,720</div>
        <div class="price-label">Total landed (FOB Ningbo, incl. FAT/SAT + shipping)</div>
        <div class="divider"></div>
        <div class="kv-list">
          <span class="kv-key">Equipment subtotal</span><span class="kv-val">$748,220</span>
          <span class="kv-key">FAT/SAT cost</span><span class="kv-val">$10,500</span>
          <span class="kv-key">Inland freight</span><span class="kv-val">$3,000</span>
          <span class="kv-key">Lead time</span><span class="kv-val">120 working days</span>
          <span class="kv-key">Payment split</span><span class="kv-val">50% / 50%</span>
          <span class="kv-key">No. of machines</span><span class="kv-val">13 line items (A1–A13)</span>
          <span class="kv-key">FDA 21 CFR Part 11</span><span class="kv-val" style="color:var(--green)">✓ Included on key machines</span>
          <span class="kv-key">IQ/OQ/DQ/SOP/FAT</span><span class="kv-val" style="color:var(--green)">✓ Canaan standard docs</span>
        </div>
      </div>
      <div class="vendor-card urban">
        <h2>Urban Machinery Co., Ltd</h2>
        <div class="location">Ruian, Zhejiang · UBM-CN-20260622001/002 · 22 Jun 2026</div>
        <div class="price-big urban">USD $343,605</div>
        <div class="price-label">Total (FOB Shanghai) — Line 1 + Line 2, no FAT/SAT included</div>
        <div class="divider"></div>
        <div class="kv-list">
          <span class="kv-key">Line 1 (Granulation)</span><span class="kv-val">$175,125</span>
          <span class="kv-key">Line 2 (Packaging)</span><span class="kv-val">$168,480</span>
          <span class="kv-key">Lead time (Line 1)</span><span class="kv-val">60 working days</span>
          <span class="kv-key">Lead time (Line 2)</span><span class="kv-val">40 working days</span>
          <span class="kv-key">Payment split</span><span class="kv-val">30% / 70%</span>
          <span class="kv-key">No. of machines</span><span class="kv-val">16 line items across 2 quotes</span>
          <span class="kv-key">FDA 21 CFR Part 11</span><span class="kv-val" style="color:var(--yellow)">Not explicitly stated</span>
          <span class="kv-key">IQ/OQ/DQ/SOP/FAT</span><span class="kv-val" style="color:var(--yellow)">Not stated in quotes</span>
        </div>
      </div>
    </div>

    <div class="savings-bar">
      <div>
        <div class="label">Price differential</div>
        <div class="number">$418,115</div>
      </div>
      <div class="note">Urban is <strong style="color:var(--urban-color)">55% cheaper</strong> at headline price — but this requires significant capability-adjusted analysis. Canaan covers a much larger scope of capability at production scale.</div>
    </div>

    <div class="ratio-bar">
      <h4>Cost concentration by line segment</h4>
      <div class="bar-row">
        <div class="bar-label">Canaan — Granulation</div>
        <div class="bar-track"><div class="bar-fill canaan" style="width:57%"></div></div>
        <div class="bar-val" style="color:var(--canaan-color)">$424,400</div>
      </div>
      <div class="bar-row">
        <div class="bar-label">Canaan — Packaging/Finishing</div>
        <div class="bar-track"><div class="bar-fill canaan" style="width:43%"></div></div>
        <div class="bar-val" style="color:var(--canaan-color)">$323,820</div>
      </div>
      <div class="bar-row">
        <div class="bar-label">Urban — Granulation</div>
        <div class="bar-track"><div class="bar-fill urban" style="width:23%"></div></div>
        <div class="bar-val" style="color:var(--urban-color)">$175,125</div>
      </div>
      <div class="bar-row">
        <div class="bar-label">Urban — Packaging/Finishing</div>
        <div class="bar-track"><div class="bar-fill urban" style="width:22%"></div></div>
        <div class="bar-val" style="color:var(--urban-color)">$168,480</div>
      </div>
    </div>

    <div class="section-label">Equipment scope comparison — what each vendor offers</div>
    <table class="comp-table">
      <thead>
        <tr>
          <th>Category</th>
          <th class="canaan-col">Canaan Model</th>
          <th class="canaan-col">Canaan</th>
          <th class="urban-col">Urban Model</th>
          <th class="urban-col">Urban</th>
          <th class="diff-col">Delta</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="cat-col">Vibro Sifter</td>
          <td class="model-col">S49-800-L-2S</td>
          <td class="price-cell canaan">$6,160</td>
          <td class="model-col">ZS-800</td>
          <td class="price-cell urban">$3,360</td>
          <td class="diff-cell cheaper">Urban −$2,800</td>
        </tr>
        <tr>
          <td class="cat-col">High Shear Mixer + wet mill + binder tank + vacuum feed</td>
          <td class="model-col">LHS75<br><span class="spec-warning">15–30 kg/batch · low platform</span></td>
          <td class="price-cell canaan">$113,490</td>
          <td class="model-col">GHL-250 + GZL-200 + ZKS-2<br><span class="spec-highlight">80 kg/batch — 2.7× capacity</span></td>
          <td class="price-cell urban">$35,200</td>
          <td class="diff-cell cheaper">Urban −$78,290</td>
        </tr>
        <tr>
          <td class="cat-col">Fluid-bed Dryer</td>
          <td class="model-col">FZ30<br><span class="spec-warning">10–30 kg/batch</span></td>
          <td class="price-cell canaan">$93,030</td>
          <td class="model-col">FG-80<br><span class="spec-highlight">80 kg/batch — 2.7× capacity</span></td>
          <td class="price-cell urban">$29,800</td>
          <td class="diff-cell cheaper">Urban −$63,230</td>
        </tr>
        <tr>
          <td class="cat-col">Dry Mill / Post-granulation</td>
          <td class="model-col">ZLT100 + QVC<br><span class="spec-text">10–100 kg/h</span></td>
          <td class="price-cell canaan">$32,820</td>
          <td class="model-col">NTZS-200<br><span class="spec-text">300–500 kg/batch</span></td>
          <td class="price-cell urban">$21,500</td>
          <td class="diff-cell cheaper">Urban −$11,320</td>
        </tr>
        <tr>
          <td class="cat-col">Bin Blender + IBC Bin(s)</td>
          <td class="model-col">HTD200 + IPC (200L max)<br><span class="spec-text">3 × 200L pharma bins</span></td>
          <td class="price-cell canaan">$77,180</td>
          <td class="model-col">HTD-250 + 250L IBC<br><span class="spec-text">1 × 250L bin</span></td>
          <td class="price-cell urban">$30,350</td>
          <td class="diff-cell cheaper">Urban −$46,830</td>
        </tr>
        <tr>
          <td class="cat-col">Roller Compactor</td>
          <td class="model-col">LGP150/50II<br><span class="spec-text">20–80 kg/h; 2× QVC + chiller</span></td>
          <td class="price-cell canaan">$101,720</td>
          <td class="model-col">GK-50<br><span class="spec-text">30–60 kg/h; chiller included</span></td>
          <td class="price-cell urban">$46,500</td>
          <td class="diff-cell cheaper">Urban −$55,220</td>
        </tr>
        <tr>
          <td class="cat-col">Solution Tank</td>
          <td class="model-col">Included in HSM</td>
          <td class="price-cell canaan">—</td>
          <td class="model-col">100L Jacked SS316L</td>
